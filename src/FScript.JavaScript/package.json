{
  "name": "@magnusopera/fscript",
  "version": "0.0.0",
  "description": "Fable-compiled JavaScript facade for the FScript language engine.",
  "type": "module",
  "main": "./dist/Library.js",
  "exports": "./dist/Library.js",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "dotnet fable FScript.JavaScript.fsproj --outDir dist --sourceMaps false && node scripts/prepare-package.mjs",
    "test": "node --test test/*.test.mjs"
  },
  "keywords": [
    "fscript",
    "fable",
    "fsharp",
    "scripting",
    "interpreter"
  ],
  "license": "MIT",
  "homepage": "https://magnusopera.github.io/FScript/manual/embedding/fable-javascript",
  "bugs": {
    "url": "https://github.com/MagnusOpera/FScript/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MagnusOpera/FScript.git",
    "directory": "src/FScript.JavaScript"
  },
  "publishConfig": {
    "access": "public"
  }
}
